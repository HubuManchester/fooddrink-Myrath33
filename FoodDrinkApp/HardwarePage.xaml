<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FoodDrinkApp.HardwarePage"
             Title="Hardware Demo"
             BackgroundColor="{AppThemeBinding Light=#F5F7FA, Dark=#121212}">
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="16">
            <Label Text="📱 Device Features" FontSize="24" FontAttributes="Bold" TextColor="#1E7F7C" />

            <Border BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E1E1E}" Padding="16">
                <VerticalStackLayout Spacing="12">
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Text="Camera" FontSize="16" FontAttributes="Bold" TextColor="#E67E22" />
                        <Button Grid.Column="1" Text="Take photo" BackgroundColor="#1E7F7C" TextColor="White" CornerRadius="8" Clicked="OnTakePhotoClicked" />
                    </Grid>
                    <Border BackgroundColor="#F3F4F6" HeightRequest="200" StrokeThickness="0">
                        <Image x:Name="FoodPhoto" Aspect="AspectFill" />
                    </Border>
                </VerticalStackLayout>
            </Border>

            <Border BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E1E1E}" Padding="16">
                <VerticalStackLayout Spacing="12">
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Text="Location" FontSize="16" FontAttributes="Bold" TextColor="#E67E22" />
                        <Button Grid.Column="1" Text="Get location" BackgroundColor="#1E7F7C" TextColor="White" CornerRadius="8" Clicked="OnGetLocationClicked" />
                    </Grid>
                    <Label x:Name="LocationLabel" FontSize="14" TextColor="{AppThemeBinding Light=#4B5563, Dark=#D1D5DB}" />
                    <Label x:Name="CoordinateLabel" FontSize="12" TextColor="{AppThemeBinding Light=#6B7280, Dark=#9CA3AF}" />
                </VerticalStackLayout>
            </Border>

            <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                <Button Text="Read help" BackgroundColor="#1E7F7C" TextColor="White" CornerRadius="8" Clicked="OnReadHelpClicked" />
                <Button Text="Stop speech" BackgroundColor="{AppThemeBinding Light=#F3F4F6, Dark=#2D2D2D}" TextColor="#1E7F7C" CornerRadius="8" Clicked="OnStopSpeechClicked" />
            </Grid>

            <Button Text="Haptic feedback" BackgroundColor="#E67E22" TextColor="White" CornerRadius="8" Clicked="OnFeedbackClicked" />

            <Border BackgroundColor="#FEE2E2" Padding="12">
                <VerticalStackLayout Spacing="6">
                    <Label x:Name="HardwareStatusLabel" Text="Ready." FontAttributes="Bold" TextColor="#B91C1C" />
                    <Label x:Name="FeedbackCountLabel" Text="Haptic tests: 0" FontSize="13" TextColor="#6B7280" />
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>