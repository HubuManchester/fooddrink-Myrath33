<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FoodDrinkApp.SettingsPage"
             Title="Settings"
             BackgroundColor="{AppThemeBinding Light=#F5F7FA, Dark=#121212}">
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="16">
            <Label Text="⚙️ Appearance &amp; Accessibility" 
                   FontSize="24" 
                   FontAttributes="Bold" 
                   TextColor="#1E7F7C" />

            <Border BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E1E1E}" Padding="16">
                <VerticalStackLayout Spacing="16">
                    <Grid RowDefinitions="Auto,Auto" RowSpacing="8">
                        <Label Text="Theme" FontSize="16" FontAttributes="Bold" TextColor="#E67E22" />
                        <Picker x:Name="ThemePicker" Title="Choose theme" SelectedIndexChanged="OnThemeChanged">
                            <Picker.Items>
                                <x:String>System default</x:String>
                                <x:String>Light theme</x:String>
                                <x:String>Dark theme</x:String>
                            </Picker.Items>
                        </Picker>
                    </Grid>

                    <BoxView HeightRequest="1" BackgroundColor="#E5E7EB" />

                    <Grid ColumnDefinitions="*,Auto">
                        <VerticalStackLayout>
                            <Label Text="Large Text Mode" FontSize="16" FontAttributes="Bold" TextColor="#1E7F7C" />
                            <Label Text="Increase text size for readability" FontSize="13" TextColor="{AppThemeBinding Light=#6B7280, Dark=#9CA3AF}" />
                        </VerticalStackLayout>
                        <Switch x:Name="LargeTextSwitch" Grid.Column="1" Toggled="OnLargeTextToggled" />
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <Border BackgroundColor="#E0F2F1" Padding="16">
                <VerticalStackLayout Spacing="8">
                    <Label x:Name="LargeTextPreviewTitle" Text="Large text preview" FontSize="18" FontAttributes="Bold" TextColor="#1E7F7C" />
                    <Label x:Name="LargeTextPreviewBody" Text="Enable the switch above to see the effect." FontSize="14" TextColor="#0F5E5C" />
                </VerticalStackLayout>
            </Border>

            <Label x:Name="SettingsStatusLabel" Text="Settings ready." FontAttributes="Bold" TextColor="#1E7F7C" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>