<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:FoodDrinkApp.Models"
             x:Class="FoodDrinkApp.MainPage"
             Title="NutriBite"
             BackgroundColor="{AppThemeBinding Light=#F5F7FA, Dark=#121212}">
    <Grid RowDefinitions="Auto,*">
        <!-- 简化头部 -->
        <Border Padding="16,12" BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E1E1E}">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                <SearchBar x:Name="SearchFoodBar"
                           Placeholder="Search food, category..."
                           TextChanged="OnSearchTextChanged"
                           SearchButtonPressed="OnSearchButtonPressed"
                           BackgroundColor="{AppThemeBinding Light=#F3F4F6, Dark=#2D2D2D}"
                           TextColor="{AppThemeBinding Light=#1F2937, Dark=#F9FAFB}"
                           PlaceholderColor="#9CA3AF" />
                <Button Grid.Column="1"
                        Text="Add"
                        BackgroundColor="#1E7F7C"
                        TextColor="White"
                        FontAttributes="Bold"
                        CornerRadius="8"
                        Clicked="OnAddClicked" />
            </Grid>
        </Border>

        <RefreshView Grid.Row="1" x:Name="FoodRefreshView" Refreshing="OnRefreshing">
            <CollectionView x:Name="FoodCollection"
                            SelectionMode="None"
                            EmptyView="No matching food or drink records."
                            Margin="16,12,16,20">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:FoodItem">
                        <Border StrokeThickness="0"
                                BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E1E1E}"
                                Padding="0"
                                Margin="0,0,0,12">
                            <Border.Shadow>
                                <Shadow Brush="#20000000" Offset="0,2" Radius="6" Opacity="0.1" />
                            </Border.Shadow>
                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12" Padding="16">
                                <!-- 左侧装饰条 -->
                                <BoxView BackgroundColor="#1E7F7C" WidthRequest="4" HeightRequest="40" VerticalOptions="Center" />
                                <Grid Grid.Column="1" RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="6">
                                    <Label Text="{Binding Name}"
                                           FontSize="18"
                                           FontAttributes="Bold"
                                           TextColor="{AppThemeBinding Light=#1F2937, Dark=#F9FAFB}" />
                                    <Label Grid.Row="1"
                                           Text="{Binding Description}"
                                           FontSize="14"
                                           TextColor="{AppThemeBinding Light=#6B7280, Dark=#9CA3AF}"
                                           LineBreakMode="TailTruncation" />
                                    <Label Grid.Row="2"
                                           Text="{Binding MacroSummary}"
                                           FontSize="13"
                                           TextColor="#1E7F7C" />
                                    <Grid Grid.Row="3" ColumnDefinitions="*,Auto">
                                        <Label Text="{Binding Category}"
                                               FontSize="12"
                                               FontAttributes="Bold"
                                               TextColor="#E67E22" />
                                        <Button Grid.Column="1"
                                                Text="Details"
                                                Padding="12,6"
                                                BackgroundColor="#1E7F7C"
                                                TextColor="White"
                                                CornerRadius="20"
                                                CommandParameter="{Binding Id}"
                                                Clicked="OnDetailsClicked" />
                                    </Grid>
                                </Grid>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>
    </Grid>
</ContentPage>