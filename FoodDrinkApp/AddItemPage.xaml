<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FoodDrinkApp.AddItemPage"
             Title="Add Record"
             BackgroundColor="{AppThemeBinding Light=#F5F7FA, Dark=#121212}">
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="16">
            <Label Text="✍️ Log your meal"
                   FontSize="24"
                   FontAttributes="Bold"
                   TextColor="{AppThemeBinding Light=#1E7F7C, Dark=#4DD0CE}" />

            <Border BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E1E1E}"
                    StrokeThickness="0"
                    Padding="16">
                <Border.Shadow>
                    <Shadow Brush="#15000000" Offset="0,2" Radius="6" />
                </Border.Shadow>
                <VerticalStackLayout Spacing="12">
                    <Label Text="📋 Basic info" FontSize="16" FontAttributes="Bold" TextColor="#E67E22" />
                    <Entry x:Name="NameEntry" Placeholder="Name (required)" />
                    <Picker x:Name="CategoryPicker" Title="Select category">
                        <Picker.Items>
                            <x:String>Breakfast</x:String>
                            <x:String>Lunch</x:String>
                            <x:String>Dinner</x:String>
                            <x:String>Snack</x:String>
                            <x:String>Drink</x:String>
                        </Picker.Items>
                    </Picker>
                    <Editor x:Name="DescriptionEditor"
                            Placeholder="Description, ingredients, flavor..."
                            AutoSize="TextChanges"
                            HeightRequest="100" />
                </VerticalStackLayout>
            </Border>

            <Border BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E1E1E}"
                    StrokeThickness="0"
                    Padding="16">
                <Border.Shadow>
                    <Shadow Brush="#15000000" Offset="0,2" Radius="6" />
                </Border.Shadow>
                <VerticalStackLayout Spacing="12">
                    <Label Text="🔢 Nutrition" FontSize="16" FontAttributes="Bold" TextColor="#1E7F7C" />
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                        <Entry x:Name="CaloriesEntry" Placeholder="Calories (kcal)" Keyboard="Numeric" />
                        <Entry x:Name="ProteinEntry" Grid.Column="1" Placeholder="Protein (g)" Keyboard="Numeric" />
                    </Grid>
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                        <Entry x:Name="CarbsEntry" Placeholder="Carbs (g)" Keyboard="Numeric" />
                        <Entry x:Name="FatEntry" Grid.Column="1" Placeholder="Fat (g)" Keyboard="Numeric" />
                    </Grid>
                    <Entry x:Name="AllergyEntry" Placeholder="Allergy / dietary notes" />
                </VerticalStackLayout>
            </Border>

            <Border x:Name="ValidationPanel"
                    IsVisible="False"
                    BackgroundColor="#FEE2E2"
                    StrokeThickness="0"
                    Padding="12">
                <Label x:Name="ValidationLabel" TextColor="#B91C1C" FontAttributes="Bold" />
            </Border>

            <Button Text="💾 Save record"
                    BackgroundColor="#1E7F7C"
                    TextColor="White"
                    FontAttributes="Bold"
                    CornerRadius="8"
                    Clicked="OnSaveClicked" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>