<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FoodDrinkApp.FoodDetailPage"
             Title="Nutrition Details"
             BackgroundColor="{AppThemeBinding Light=#F5F7FA, Dark=#121212}">
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="16">
            <!-- 主卡片 -->
            <Border BackgroundColor="#1E7F7C" StrokeThickness="0" Padding="20">
                <VerticalStackLayout Spacing="8">
                    <Label x:Name="NameLabel" FontSize="26" FontAttributes="Bold" TextColor="White" />
                    <Label x:Name="CategoryLabel" FontSize="14" TextColor="#E0F2F1" />
                    <Label x:Name="CaloriesLabel" FontSize="22" FontAttributes="Bold" TextColor="#FFE0B2" />
                </VerticalStackLayout>
            </Border>

            <!-- 营养详情卡片 -->
            <Border BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E1E1E}" StrokeThickness="0" Padding="16">
                <VerticalStackLayout Spacing="12">
                    <Label Text="📊 Nutrition overview" FontSize="16" FontAttributes="Bold" TextColor="#E67E22" />
                    <Label x:Name="MacroLabel" FontSize="15" TextColor="#1E7F7C" />
                    <BoxView HeightRequest="1" BackgroundColor="#E5E7EB" />
                    <Label x:Name="DescriptionLabel" FontSize="15" TextColor="{AppThemeBinding Light=#4B5563, Dark=#D1D5DB}" />
                    <Label x:Name="AllergyLabel" FontSize="14" FontAttributes="Bold" TextColor="#E67E22" />
                </VerticalStackLayout>
            </Border>

            <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                <Button Text="🔊 Read summary"
                        BackgroundColor="#1E7F7C"
                        TextColor="White"
                        CornerRadius="8"
                        Clicked="OnSpeakClicked" />
                <Button Grid.Column="1"
                        Text="⏹️ Stop"
                        BackgroundColor="{AppThemeBinding Light=#F3F4F6, Dark=#2D2D2D}"
                        TextColor="#1E7F7C"
                        CornerRadius="8"
                        Clicked="OnStopSpeechClicked" />
            </Grid>

            <Button Text="📳 Vibration reminder"
                    BackgroundColor="#E67E22"
                    TextColor="White"
                    CornerRadius="8"
                    Clicked="OnVibrateClicked" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>