<?xml version="1.0" encoding="UTF-8" ?>
<Shell x:Class="FoodDrinkApp.AppShell"
       xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
       xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
       xmlns:local="clr-namespace:FoodDrinkApp"
       Title="NutriBite"
       FlyoutBehavior="Disabled"
       Shell.BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E1E1E}"
       Shell.ForegroundColor="{AppThemeBinding Light=#1E7F7C, Dark=#4DD0CE}"
       Shell.TitleColor="{AppThemeBinding Light=#1E7F7C, Dark=#4DD0CE}"
       Shell.UnselectedColor="{AppThemeBinding Light=#9CA3AF, Dark=#6B7280}"
       Shell.TabBarBackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E1E1E}"
       Shell.TabBarForegroundColor="{AppThemeBinding Light=#1E7F7C, Dark=#4DD0CE}"
       Shell.TabBarTitleColor="{AppThemeBinding Light=#1E7F7C, Dark=#4DD0CE}"
       Shell.TabBarUnselectedColor="{AppThemeBinding Light=#9CA3AF, Dark=#6B7280}">
    <TabBar>
        <ShellContent Title="Foods" ContentTemplate="{DataTemplate local:MainPage}" Route="MainPage" />
        <ShellContent Title="Hardware" ContentTemplate="{DataTemplate local:HardwarePage}" Route="HardwarePage" />
        <ShellContent Title="Settings" ContentTemplate="{DataTemplate local:SettingsPage}" Route="SettingsPage" />
    </TabBar>
</Shell>